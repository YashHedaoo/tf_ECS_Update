# ==============================================================================
# Remote State Backend Configuration (local use)
# ==============================================================================
# Copy to backend.hcl and fill in your values, then run:
#   terraform init -backend-config=backend.hcl
#
# Create the bucket (and optional lock table) ONCE before first init:
#   aws s3 mb s3://your-tf-state-bucket --region us-east-1
#   aws dynamodb create-table \
#     --table-name terraform-locks \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH \
#     --billing-mode PAY_PER_REQUEST --region us-east-1
# ==============================================================================

bucket         = "your-tf-state-bucket"
key            = "dynatrace-oneagent/terraform.tfstate"
region         = "us-east-1"
dynamodb_table = "terraform-locks" # optional but recommended for state locking
encrypt        = true
